# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=itclub

# Application
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS) — gunakan comma untuk multiple origins
# Contoh: http://localhost:3000,https://clubit.id
FRONTEND_URL=http://localhost:3000

# JWT — WAJIB diganti di production!
JWT_SECRET=ganti-dengan-secret-yang-kuat-minimal-32-karakter
JWT_EXPIRES_IN=7d

# Rate Limiting
# TTL dalam millisecond (default: 60000 = 1 menit)
# LIMIT = max request per TTL (default: 30)
THROTTLE_TTL=60000
THROTTLE_LIMIT=30
